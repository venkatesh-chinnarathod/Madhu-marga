<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFDE7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FBC02D" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/honey_flow_progress"
            android:layout_marginTop="16dp" />

        <ProgressBar
            android:id="@+id/honeyFlowProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progress="65"
            android:progressTint="#FF8F00" />

        <EditText
            android:id="@+id/etHiveId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_hive_id"
            android:inputType="text"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/etLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_location"
            android:inputType="text"
            android:importantForAutofill="no" />

        <CheckBox
            android:id="@+id/cbQueenPresent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_queen_present" />

        <CheckBox
            android:id="@+id/cbPestsSeen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_pests_seen" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_activity_level" />

        <EditText
            android:id="@+id/etActivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_activity_level"
            android:inputType="text"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/etHoneyQty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_honey_qty"
            android:inputType="numberDecimal"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_save_log"
            android:backgroundTint="#FBC02D" />

        <TextView
            android:id="@+id/tvAlert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="#D32F2F"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>